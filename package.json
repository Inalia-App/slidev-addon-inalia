{
  "name": "slidev-addon-inalia",
  "type": "module",
  "version": "0.2.6",
  "packageManager": "pnpm@10.28.2",
  "repository": {
    "url": "https://github.com/Inalia-App/slidev-addon-inalia"
  },
  "keywords": [
    "slidev",
    "slidev-addon",
    "inalia"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js"
    },
    "./lite": {
      "types": "./lite/index.d.ts",
      "import": "./dist/lite.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./index.d.ts",
  "bin": {
    "slidev-addon-inalia": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    "components",
    "composables",
    "dist",
    "global-bottom.vue",
    "index.d.ts",
    "layouts",
    "lite.d.ts",
    "pages",
    "setup",
    "slidev.d.ts",
    "styles.css",
    "tsconfig.json",
    "types",
    "utils",
    "vite-env.d.ts",
    "vite.config.ts",
    "window.d.ts"
  ],
  "engines": {
    "slidev": ">=0.49.29"
  },
  "scripts": {
    "build": "slidev build",
    "prepack": "tsdown",
    "dev": "slidev --open",
    "dev:lite": "slidev --open slides.lite.md",
    "export": "slidev export",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "bumpp --sign",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:update": "vitest run -u"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@slidev/cli": "^52.11.5",
    "@slidev/theme-default": "latest",
    "@unovis/ts": "1.4.3-beta.0",
    "@unovis/vue": "1.4.3-beta.0",
    "@vueuse/core": "^14.2.1",
    "cac": "^6.7.14",
    "laravel-echo": "^2.2.0",
    "nypm": "^0.4.0",
    "ofetch": "^1.4.1",
    "pusher-js": "8.4.0-rc2",
    "rc9": "^2.1.2",
    "reka-ui": "^2.5.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "uncrypto": "^0.1.3",
    "uqr": "^0.1.2",
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.3.0",
    "@unocss/eslint-plugin": "^66.5.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/ui": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "bumpp": "^10.2.3",
    "eslint": "^9.35.0",
    "jsdom": "^25.0.1",
    "taze": "^19.6.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "unplugin-vue": "^7.1.1",
    "vitest": "^2.1.8",
    "vue-tsc": "^3.2.4"
  }
}
